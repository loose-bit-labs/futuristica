#!/bin/bash

set -e -o pipefail

BASE=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
source "${BASE}/../lib/based.sh"

_run_training_main() {
	local disable_meta=""
	[ "${1}" = "--disable-meta-checkpoint" ] && { disable_meta=1; shift; }

	local file=${1:-${BASE}/../images/lenna.png}

	source_conf "${BASE}/../local.conf" \
		TRAIN_DIR CHECKPOINTS_DIR TRAINING SIZE COLORSPACE \
		LOSS_FN MAPPING MODEL_SIZE MODEL_COUNT CODING EXTRAS CHECKPOINT PROGRESSIVE

	TRAINING="${TRAINING:-20}"
	SIZE="${SIZE:-512}"
	COLORSPACE="${COLORSPACE:-ycbcr}"
	LOSS_FN="${LOSS_FN:-l1}"
	MAPPING="${MAPPING:-polar}"
	MODEL_SIZE="${MODEL_SIZE:-16}"
	MODEL_COUNT="${MODEL_COUNT:-4}"
	CODING="${CODING:-3}"
	EXTRAS="${EXTRAS:-}"
	CHECKPOINT="${CHECKPOINT:-}"
	PROGRESSIVE="${PROGRESSIVE:-}"
	TRAIN_DIR="${TRAIN_DIR:-${BASE}/../run}"
	CHECKPOINTS_DIR="${CHECKPOINTS_DIR:-}"

	file=$(fullpath ${file})
	[ -f "${file}" ] || { echo "image not found: ${file}"; return 1; }

	local no_load_noise=""

	if [ -n "${CHECKPOINT}" ]; then
		CHECKPOINT=$(fullpath ${CHECKPOINT})
		[ -f "${CHECKPOINT}" ] || { echo "checkpoint not found: ${CHECKPOINT}"; return 2; }
	elif [ -n "${CHECKPOINTS_DIR}" ] && [ -z "${disable_meta}" ]; then
		local auto_ckp="${CHECKPOINTS_DIR}/s${MODEL_SIZE}_c${MODEL_COUNT}_q${CODING}_${LOSS_FN}_${COLORSPACE}_${MAPPING}.npz"
		if [ -f "${auto_ckp}" ]; then
			CHECKPOINT="${auto_ckp}"
			no_load_noise="--no_load_noise"
			echo "auto-checkpoint: ${CHECKPOINT}"
		fi
	fi

	go_train || return 3

	echo "Starting training"
	time "${BASE}/futuristica"          \
		--weights     weights.npz       \
		--generated   images/output.png \
		--loss_fn     ${LOSS_FN}        \
		--coding      ${CODING}         \
		--training    ${TRAINING}       \
		--size        ${SIZE}           \
		--image       ${file}           \
		--colorspace  ${COLORSPACE}     \
		--mapping     ${MAPPING}        \
		--checkpoint  "${CHECKPOINT}"    \
		${no_load_noise}                \
		--model_size  ${MODEL_SIZE}     \
		--model_count ${MODEL_COUNT}    \
		${PROGRESSIVE:+--progressive}   \
		${EXTRAS}                       \
		2>&1 | tee train.log || return ${?}
	echo "Training completed"

	"${BASE}/translate" weights.npz > output.glsl

	ls -lathr ./*.*
	echo "output is in ${PWD}"
	cp -i weights.npz "${BASE}/../zed.npz"
}

_run_training_main ${*}
